<!doctype html>
<html lang="en">

<head>
    {% include "meta.liquid" %}
    <title>{{ page.title }} | LFE Blog</title>
    <meta name="description" content="{{ page.description }}">

    {% include "favicon.liquid" %}
    {% include "css.liquid" %}
</head>

<body class="dark:bg-slate-900 min-h-[75rem]">
    <header class="top-nav">
    {% include "nav.liquid" %}
    </header>

    <main id="content" role="main">
      <article>
        <h1>{{ page.title }}</h1>
        {{ page.content }}
      </article>
    </main>

    {% include "foot.liquid" %}

    {% include "end-scripts.liquid" %}
</body>

</html>

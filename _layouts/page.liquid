<!doctype html>
<html lang="en">

<head>
    {% include "meta.liquid" %}
    <title>(LFE:{{ page.title }})</title>
    <meta name="description" content="{{ page.description }}">

    {% include "favicon.liquid" %}
    {% include "css.liquid" %}
</head>

<body>
    <header class="top-nav">
    {% include "nav.liquid" %}
    </header>

    <main id="content" role="main">
      <div class="masthead-container">
        <div class="masthead-section">
          <h1>{{ page.data.long_title }}</h1>
          <h2>{{ page.data.long_description }}</h2>
        </div>
      </div>

      <div class="content-section">
        {{ page.content }}
      </div>
    </main>

    {% include "foot.liquid" %}

    {% include "end-scripts.liquid" %}
</body>

</html>

<!doctype html>
<html lang="en">

<head>
    {% include "meta.liquid" %}
    <title>{{ page.title }} | LFE Blog</title>
    <meta name="description" content="LFE blog authors.">

    {% include "favicon.liquid" %}
    {% include "css.liquid" %}
</head>

<body class="dark:bg-slate-900">
    <header class="top-nav">
    {% include "nav.liquid" %}
    </header>
    {% include "blog-subnav.liquid" %}

    <main id="content" role="main">
      <section class="blog-home-section">

        <h1 class="blog-section-heading">{{ page.data.long_title }}</h1>

        {% for author in site.data.blog_resolved.authors_sorted %}

          <a href="/blog/authors/{{ author.slug }}/" class="blog-author-page-card">
            {% if author.avatar %}
            <img src="{{ author.avatar }}" alt="{{ author.name }}" class="blog-author-avatar-lg">
            {% else %}
            <div class="blog-author-initials-lg">{{ author.name | truncate: 2, "" | upcase }}</div>
            {% endif %}
            <div class="blog-author-page-info">
              <h3 class="blog-author-page-name">{{ author.name }}</h3>
              {% if author.bio %}
              <p class="blog-author-page-bio">{{ author.bio }}</p>
              {% endif %}
              <p class="blog-card-meta">{{ author.post_count }} posts</p>
            </div>
          </a>
        {% endfor %}

      </section>
    </main>

    {% include "foot.liquid" %}

    {% include "end-scripts.liquid" %}
</body>

</html>
